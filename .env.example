# =============================================================================
# Variáveis de ambiente — EXEMPLO
# =============================================================================
# INSTRUÇÕES:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores reais no .env
#   3. NUNCA faça commit do .env (ele está no .gitignore)
#
# No servidor de produção, este arquivo fica em:
#   /home/ghactions/eq14/.env
# A variável APP_IMAGE é atualizada automaticamente pelo GitHub Actions.
# =============================================================================

# Imagem Docker da aplicação (atualizada automaticamente pelo CI/CD a cada deploy)
APP_IMAGE=ghcr.io/des-sist-corp-ufpb/projeto-eq14:latest

# Banco de dados — GERENCIADO PELO PROFESSOR (compartilhado).
# O host "postgres" é resolvido dentro da rede Docker da disciplina (DB_NETWORK).
DATABASE_URL=jdbc:postgresql://postgres:5432/eq14
DATABASE_USERNAME=eq14
DATABASE_PASSWORD=senha-enviada-pelo-professor

# Nome da rede Docker (externa) da disciplina onde o container "postgres" está.
# Descubra no Portainer (aba Networks) ou pergunte ao professor.
DB_NETWORK=nome-da-rede-da-disciplina

# A app é publicada em 127.0.0.1:8114 do host (mapeada no docker-compose.prod.yml).
# O Caddy já faz proxy de https://eq14.dsc.rodrigor.com → 127.0.0.1:8114.
# A porta INTERNA da app continua 8080 — não é necessário alterar SERVER_PORT.
