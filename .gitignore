# =============================================================================
# .gitignore — Projeto Spring Boot / Maven
# =============================================================================

# Diário local de deploy em markdown (anotações de troubleshooting — não versionar)
.deploy-changes*

# ---------------------------------------------------------------------------
# Maven
# ---------------------------------------------------------------------------
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ---------------------------------------------------------------------------
# IDEs
# ---------------------------------------------------------------------------
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# Eclipse / Spring Tool Suite
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# NetBeans
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/

# ---------------------------------------------------------------------------
# Sistema operacional
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*~

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/
spring.log

# ---------------------------------------------------------------------------
# Variáveis de ambiente — NUNCA versionar!
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
docker/data/

# ---------------------------------------------------------------------------
# Relatórios de ferramentas de qualidade/segurança
# ---------------------------------------------------------------------------
dependency-check-report.*
dependency-check-report/
spotbugsXml.xml
target/spotbugs/
target/dependency-check-report/

# ---------------------------------------------------------------------------
# Trivy
# ---------------------------------------------------------------------------
trivy-results.json
trivy-results.sarif

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
*.pid
*.seed
*.pid.lock
HELP.md
